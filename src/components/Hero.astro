---
import VideoPlayer from "./VideoPlayer.astro";
import { t, localizedPath, type Lang } from "../i18n/utils";
import { portfolioStats } from "../data/shows";
import { stats as traction } from "../data/stats";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const ps = portfolioStats();

// Studio sizzle reel (bilingual) — stable committed assets on the blog's R2.
const REEL = "https://pub-acd1440124614ccb9c0b6dcdfd9cd4af.r2.dev/married-to-the-alpha";
const reelSrc = `${REEL}/sizzle${lang === "tr" ? ".tr" : ""}.mp4?v=2`;
const reelPoster = lang === "tr" ? "/posters/teaser.tr.jpg" : "/posters/teaser.jpg";

const stats = [
  { value: String(ps.shows), label: t(lang, "hero.stat1Label") },
  { value: `${traction.totals.episodes}+`, label: t(lang, "hero.stat2Label") },
  { value: String(ps.languages), label: t(lang, "hero.stat3Label") },
];
---

<section class="film-grain relative overflow-hidden bg-cinematic px-6">
  <div class="aurora"></div>
  <div
    class="relative z-10 mx-auto grid max-w-6xl items-center gap-12 pb-16 pt-16 sm:pb-24 sm:pt-24 lg:grid-cols-[1.1fr_0.9fr]"
  >
    <div>
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-accent/30 bg-accent/5 px-4 py-1.5 font-mono text-xs text-accent-ink"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        {t(lang, "hero.eyebrow")}
      </div>

      <h1
        class="font-display text-4xl font-extrabold leading-[1.05] tracking-tight text-ink sm:text-6xl lg:text-7xl"
      >
        {t(lang, "hero.title1")}<br />
        <span class="gold-text">{t(lang, "hero.title2")}</span>
      </h1>

      <p class="mt-6 max-w-xl text-lg leading-relaxed text-neutral-600">
        {t(lang, "hero.subtitle")}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={localizedPath("/contact", lang)}
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-ink transition-all hover:bg-accent-warm hover:shadow-glow-md"
        >
          {t(lang, "hero.ctaPrimary")}
        </a>
        <a
          href={localizedPath("/work", lang)}
          class="inline-flex items-center gap-2 rounded-lg border border-border px-6 py-3 text-sm font-semibold text-neutral-800 transition-colors hover:border-accent/50 hover:text-accent-ink"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
          {t(lang, "hero.ctaSecondary")}
        </a>
      </div>

      <dl class="mt-12 grid grid-cols-3 gap-6 border-t border-border/60 pt-8">
        {
          stats.map((s) => (
            <div>
              <dt class="font-display text-xl font-bold text-ink sm:text-2xl">{s.value}</dt>
              <dd class="mt-1.5 font-mono text-[11px] uppercase leading-snug tracking-wider text-ink-faint">{s.label}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="relative mx-auto w-full max-w-[300px] lg:max-w-[340px]">
      <VideoPlayer
        src={reelSrc}
        poster={reelPoster}
        autoplay
        loop
        muted
        controls={false}
        label={t(lang, "meta.siteTitle")}
      />
    </div>
  </div>
</section>
