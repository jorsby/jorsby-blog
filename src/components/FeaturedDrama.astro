---
import EpisodeCard from "./EpisodeCard.astro";
import GenreBadge from "./GenreBadge.astro";
import LanguageBadges from "./LanguageBadges.astro";
import { flagship, L } from "../data/shows";
import { t, localizedPath, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const d = flagship();
const showPath = localizedPath(`/shows/${d.slug}`, lang);
const preview = d.episodes.slice(0, 5);
---

<section class="fade-in border-t border-border/50 px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <p class="mb-3 font-mono text-xs uppercase tracking-wider text-accent-ink">
      {t(lang, "featured.eyebrow")}
    </p>

    <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="font-display text-3xl font-extrabold text-ink sm:text-5xl">{L(d.title, lang)}</h2>
        <p class="mt-3 max-w-xl text-neutral-600">{L(d.tagline, lang)}</p>
      </div>
      <div class="flex flex-col gap-2 sm:items-end">
        <div class="flex items-center gap-2">
          <span class="font-mono text-xs text-neutral-500">{t(lang, "featured.genreLabel")}:</span>
          <GenreBadge genre={d.genre} lang={lang} />
        </div>
        <div class="flex items-center gap-2">
          <span class="font-mono text-xs text-neutral-500">{t(lang, "featured.langLabel")}</span>
          <LanguageBadges languages={d.languages} />
        </div>
      </div>
    </div>

    <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-5">
      {preview.map((ep, i) => <EpisodeCard episode={ep} lang={lang} index={i} href={showPath} />)}
    </div>

    <a
      href={showPath}
      class="mt-8 inline-flex items-center gap-1 font-mono text-sm text-accent-ink transition-colors hover:text-accent-warm"
    >
      {t(lang, "featured.viewAll")}
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>
</section>
