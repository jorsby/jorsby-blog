---
import { t, localizedPath, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
---

<section class="fade-in relative overflow-hidden border-b border-border px-5 py-24 text-center sm:px-8 sm:py-36">
  <div class="aurora"></div>
  <div class="page-shell relative z-10">
    <p class="eyebrow-dim">{lang === "tr" ? "SONRAKİ ADIM" : "NEXT STEP"}</p>
    <h2 class="mx-auto mt-5 max-w-5xl font-display text-5xl uppercase leading-[0.95] text-ink sm:text-7xl lg:text-8xl">
      {t(lang, "cta.title")}
    </h2>
    <p class="mx-auto mt-5 max-w-xl leading-relaxed text-ink-faint">{t(lang, "cta.subtitle")}</p>
    <a href={localizedPath("/contact", lang)} class="button-primary mt-9 px-10 py-4" data-magnetic>
      {t(lang, "cta.button")}
      <span class="ml-2" aria-hidden="true">&rarr;</span>
    </a>
    <p class="mt-6 font-mono text-[10px] uppercase text-ink-faint">
      <a href="mailto:serhat@jorsby.ai" class="normal-case transition-colors hover:text-accent">serhat@jorsby.ai</a>
    </p>
  </div>
</section>
