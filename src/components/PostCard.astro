---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a href={`/blog/${slug}/`} class="group block rounded-lg border border-border p-6 transition-colors hover:border-accent/40 hover:bg-surface/50">
  <div class="mb-2 flex items-center gap-3 text-sm text-neutral-500">
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <h3 class="mb-2 text-xl font-semibold text-neutral-100 transition-colors group-hover:text-accent">
    {title}
  </h3>
  <p class="text-neutral-400">{description}</p>
  {tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-surface px-2.5 py-0.5 font-mono text-xs text-neutral-500">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
