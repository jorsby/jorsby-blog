---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
  readingTime?: number;
}

const { title, description, date, slug, tags = [], readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={`/blog/${slug}/`}
  class="group block rounded-xl border border-border p-6 transition-all duration-300 hover:border-accent/30 hover:bg-surface/80 hover:shadow-glow"
>
  <div class="mb-3 flex items-center gap-3 text-sm text-neutral-500">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    {readingTime && (
      <>
        <span class="text-neutral-600">&middot;</span>
        <span>{readingTime} min read</span>
      </>
    )}
  </div>
  <h3 class="mb-2 text-lg font-semibold text-neutral-100 transition-colors group-hover:text-accent sm:text-xl">
    {title}
  </h3>
  <p class="text-sm leading-relaxed text-neutral-400">{description}</p>
  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-surface-light px-2.5 py-0.5 font-mono text-xs text-neutral-500">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
