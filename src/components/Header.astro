---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { t, localizedPath, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const homePath = localizedPath("/", lang);

const navLinks = [
  { href: localizedPath("/work", lang), label: t(lang, "nav.work") },
  { href: `${homePath}#services`, label: t(lang, "nav.services") },
  { href: `${homePath}#process`, label: t(lang, "process.title") },
  { href: localizedPath("/about", lang), label: t(lang, "nav.about") },
  { href: localizedPath("/contact", lang), label: t(lang, "nav.contact") },
];
---

<header class="sticky top-0 z-40 border-b border-border bg-bg/90 px-5 backdrop-blur-xl sm:px-8">
  <nav class="mx-auto flex h-[72px] max-w-[1280px] items-center justify-between">
    <a
      href={homePath}
      class="flex shrink-0 items-baseline gap-2 text-ink transition-colors hover:text-accent"
    >
      <span class="font-display text-2xl uppercase">Jorsby</span>
      <span class="font-mono text-[10px] uppercase text-accent">Media</span>
    </a>
    <div class="flex items-center gap-2 sm:gap-3">
      <div class="hidden items-center gap-6 lg:flex">
        {
          navLinks.map(({ href, label }) => (
            <a
              href={href}
              data-scramble
              aria-label={label}
              class="font-mono text-[11px] uppercase text-ink-faint transition-colors hover:text-accent"
            >
              {label}
            </a>
          ))
        }
      </div>
      <div class="hidden sm:block">
        <LanguageSwitcher lang={lang} />
      </div>
      <a
        href={localizedPath("/contact", lang)}
        data-magnetic
        class="hidden min-h-10 items-center rounded-full bg-accent px-5 text-xs font-extrabold uppercase text-bg transition-colors hover:bg-accent-warm sm:inline-flex"
      >
        {t(lang, "nav.cta")}
      </a>
      <button
        id="menu-toggle"
        type="button"
        class="flex h-10 w-10 flex-col items-center justify-center gap-1.5 border border-border text-ink transition-colors hover:border-accent hover:text-accent lg:hidden"
        aria-label={lang === "tr" ? "Menüyü aç" : "Open menu"}
        data-open-label={lang === "tr" ? "Menüyü aç" : "Open menu"}
        data-close-label={lang === "tr" ? "Menüyü kapat" : "Close menu"}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="menu-line block h-px w-5 bg-current transition-transform"></span>
        <span class="menu-line block h-px w-5 bg-current transition-opacity"></span>
        <span class="menu-line block h-px w-5 bg-current transition-transform"></span>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-border pb-5 lg:hidden">
    <nav class="mx-auto max-w-[1280px] pt-2">
      {
        navLinks.map(({ href, label }) => (
          <a
            href={href}
            class="flex items-center border-b border-border px-1 py-4 font-display text-2xl uppercase text-ink transition-colors hover:text-accent"
          >
            {label}
          </a>
        ))
      }
      <div class="mt-4 flex items-center justify-between sm:hidden">
        <LanguageSwitcher lang={lang} />
        <a href={localizedPath("/contact", lang)} class="button-primary min-h-10 px-5 text-xs">
          {t(lang, "nav.cta")}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const lines = toggle?.querySelectorAll<HTMLElement>(".menu-line");
  if (toggle && menu && lines?.length === 3) {
    const setOpen = (open: boolean) => {
      menu.classList.toggle("hidden", !open);
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? toggle.dataset.closeLabel || "Close menu" : toggle.dataset.openLabel || "Open menu");
      lines[0].classList.toggle("translate-y-[7px]", open);
      lines[0].classList.toggle("rotate-45", open);
      lines[1].classList.toggle("opacity-0", open);
      lines[2].classList.toggle("-translate-y-[7px]", open);
      lines[2].classList.toggle("-rotate-45", open);
    };
    toggle.addEventListener("click", () => setOpen(menu.classList.contains("hidden")));
    menu.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => setOpen(false)));
  }
</script>
