---
import { shows } from "../data/shows";
import { L } from "../data/shows";
import { t, localizedPath, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const year = new Date().getFullYear();

const pageLinks = [
  { href: localizedPath("/work", lang), label: t(lang, "nav.work") },
  { href: `${localizedPath("/", lang)}#services`, label: t(lang, "nav.services") },
  { href: localizedPath("/about", lang), label: t(lang, "nav.about") },
  { href: localizedPath("/contact", lang), label: t(lang, "nav.contact") },
];

const showLinks = [...shows]
  .sort((a, b) => a.order - b.order)
  .map((s) => ({ href: localizedPath(`/shows/${s.slug}`, lang), label: L(s.title, lang) }));

const linkCls = "text-sm text-neutral-600 transition-colors hover:text-neutral-900";
---

<footer class="mt-auto border-t border-border/50 px-6">
  <div class="mx-auto max-w-6xl py-12">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-[1.3fr_0.8fr_1fr_1fr]">
      <!-- Brand -->
      <div>
        <a href={localizedPath("/", lang)} class="font-mono text-lg font-semibold text-neutral-900">
          jorsby<span class="text-accent-ink">.</span>ai
        </a>
        <p class="mt-3 whitespace-pre-line text-sm leading-relaxed text-ink-faint">
          {t(lang, "footer.brand")}
        </p>
      </div>

      <!-- Pages -->
      <div>
        <h4 class="eyebrow-dim mb-4">{t(lang, "footer.pages")}</h4>
        <ul class="space-y-2.5">
          {
            pageLinks.map(({ href, label }) => (
              <li>
                <a href={href} class={linkCls}>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Shows -->
      <div>
        <h4 class="eyebrow-dim mb-4">{t(lang, "footer.shows")}</h4>
        <ul class="space-y-2.5">
          {
            showLinks.map(({ href, label }) => (
              <li>
                <a href={href} class={linkCls}>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="eyebrow-dim mb-4">{t(lang, "footer.connect")}</h4>
        <ul class="space-y-2.5">
          <li>
            <a href="mailto:serhat@jorsby.ai" class={linkCls}>serhat@jorsby.ai</a>
          </li>
          <li>
            <a href={localizedPath("/contact", lang)} class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-ink transition-colors hover:text-accent-deep">
              {t(lang, "nav.cta")}
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 border-t border-border/50 pt-6 text-sm text-neutral-600">
      &copy; {year} {t(lang, "footer.copyright")}
    </div>
  </div>
</footer>
