---
import { t, localizedPath, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const year = new Date().getFullYear();

const pageLinks = [
  { href: localizedPath("/work", lang), label: t(lang, "nav.work") },
  { href: `${localizedPath("/", lang)}#services`, label: t(lang, "nav.services") },
  { href: localizedPath("/about", lang), label: t(lang, "nav.about") },
  { href: localizedPath("/contact", lang), label: t(lang, "nav.contact") },
];

const linkCls = "text-sm text-ink-faint transition-colors hover:text-accent";
---

<footer class="mt-auto border-t border-border bg-[#050505] px-5 sm:px-8">
  <div class="mx-auto max-w-[1280px] py-14">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-3 lg:grid-cols-[1.5fr_0.8fr_0.9fr]">
      <div>
        <a href={localizedPath("/", lang)} class="flex items-baseline gap-2 text-ink transition-colors hover:text-accent">
          <span class="font-display text-3xl uppercase">Jorsby</span>
          <span class="font-mono text-[10px] uppercase text-accent">Media</span>
        </a>
        <p class="mt-3 whitespace-pre-line text-sm leading-relaxed text-ink-faint">
          {t(lang, "footer.brand")}
        </p>
        <a href="mailto:serhat@jorsby.ai" class="mt-6 inline-block font-mono text-xs text-accent hover:text-accent-warm">serhat@jorsby.ai</a>
      </div>

      <div>
        <h4 class="eyebrow-dim mb-4">{t(lang, "footer.pages")}</h4>
        <ul class="space-y-2.5">
          {
            pageLinks.map(({ href, label }) => (
              <li>
                <a href={href} class={linkCls}>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="eyebrow-dim mb-4">{t(lang, "footer.connect")}</h4>
        <ul class="space-y-2.5">
          <li>
            <a href={localizedPath("/contact", lang)} class="inline-flex items-center gap-1.5 text-sm font-semibold uppercase text-accent transition-colors hover:text-accent-warm">
              {t(lang, "nav.cta")}
              <span aria-hidden="true">&rarr;</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-3 border-t border-border pt-5 font-mono text-[10px] uppercase text-ink-faint sm:flex-row sm:items-center sm:justify-between">
      <span>&copy; {year} {t(lang, "footer.copyright")}</span>
      <a href="#top" class="transition-colors hover:text-accent">{lang === "tr" ? "Başa dön ↑" : "Back to top ↑"}</a>
      <span>{lang === "tr" ? "Yapay zeka ile üretildi" : "Directed with AI"} <span class="text-accent">●</span></span>
    </div>
  </div>
</footer>
