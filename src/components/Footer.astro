---
const year = new Date().getFullYear();

const pageLinks = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
  { href: "/rss.xml", label: "RSS Feed" },
];

const socialLinks = [
  { href: "https://x.com/jorsby_en", label: "Twitter/X" },
  { href: "https://discord.gg/clawd", label: "Discord" },
  { href: "https://github.com/jorsby", label: "GitHub" },
];
---

<footer class="mt-auto border-t border-border/50">
  <div class="mx-auto max-w-5xl px-6 py-12">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href="/" class="font-mono text-lg font-semibold text-neutral-100">
          jorsby<span class="text-accent">.</span>ai
        </a>
        <p class="mt-3 text-sm leading-relaxed text-neutral-500">
          AI automation & agent systems<br />built in public.
        </p>
      </div>

      <!-- Pages -->
      <div>
        <h4 class="mb-4 font-mono text-xs uppercase tracking-wider text-neutral-500">Pages</h4>
        <ul class="space-y-2.5">
          {pageLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-neutral-400 transition-colors hover:text-neutral-100">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="mb-4 font-mono text-xs uppercase tracking-wider text-neutral-500">Connect</h4>
        <ul class="space-y-2.5">
          {socialLinks.map(({ href, label }) => (
            <li>
              <a href={href} target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-400 transition-colors hover:text-neutral-100">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 border-t border-border/50 pt-6 text-sm text-neutral-600">
      &copy; {year} Jorsby. All rights reserved.
    </div>
  </div>
</footer>
