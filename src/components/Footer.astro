---
import { t, localizedPath, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const year = new Date().getFullYear();

const pageLinks = [
  { href: localizedPath("/work", lang), label: t(lang, "nav.work") },
  { href: localizedPath("/about", lang), label: t(lang, "nav.about") },
  { href: localizedPath("/contact", lang), label: t(lang, "nav.contact") },
];

const socialLinks = [
  { href: "mailto:serhat@jorsby.ai", label: "serhat@jorsby.ai", external: false },
];
---

<footer class="mt-auto border-t border-border/50">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href={localizedPath("/", lang)} class="font-mono text-lg font-semibold text-neutral-900">
          jorsby<span class="text-accent-ink">.</span>ai
        </a>
        <p class="mt-3 whitespace-pre-line text-sm leading-relaxed text-neutral-500">
          {t(lang, "footer.brand")}
        </p>
      </div>

      <!-- Studio -->
      <div>
        <h4 class="mb-4 font-mono text-xs uppercase tracking-wider text-neutral-500">
          {t(lang, "footer.studio")}
        </h4>
        <ul class="space-y-2.5">
          {
            pageLinks.map(({ href, label }) => (
              <li>
                <a href={href} class="text-sm text-neutral-600 transition-colors hover:text-neutral-900">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h4 class="mb-4 font-mono text-xs uppercase tracking-wider text-neutral-500">
          {t(lang, "footer.connect")}
        </h4>
        <ul class="space-y-2.5">
          {
            socialLinks.map(({ href, label, external }) => (
              <li>
                <a
                  href={href}
                  {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                  class="text-sm text-neutral-600 transition-colors hover:text-neutral-900"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 border-t border-border/50 pt-6 text-sm text-neutral-600">
      &copy; {year} {t(lang, "footer.copyright")}
    </div>
  </div>
</footer>
