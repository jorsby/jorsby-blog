---
import GenreBadge from "./GenreBadge.astro";
import LanguageBadges from "./LanguageBadges.astro";
import SeriesSocial from "./SeriesSocial.astro";
import { L, showSocial, type Show } from "../data/shows";
import { t, type Lang } from "../i18n/utils";

interface Props {
  show: Show;
  lang?: Lang;
}

const { show, lang = "en" } = Astro.props;
const title = L(show.title, lang);
const synopsis = L(show.synopsis, lang);
const featured = show.episodes[0];
const featSrc = featured?.video[lang] ?? featured?.video.en ?? featured?.video.tr ?? "";
const turkishAudio = lang === "en" && show.primaryLang === "tr";
const social = showSocial(show, lang);
---

<section id="top" class="page-hero film-grain">
  <div class="aurora"></div>
  <div class="page-shell relative z-10 grid gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
    <div>
      <p class="eyebrow mb-5">{t(lang, "work.indexEyebrow")} / {String(show.order).padStart(2, "0")}</p>
      <div class="mb-5 flex flex-wrap items-center gap-2">
        <GenreBadge genre={show.genre} lang={lang} />
        <LanguageBadges languages={show.languages} />
      </div>
      <h1 class="max-w-4xl font-display text-5xl uppercase leading-[0.96] text-ink sm:text-7xl lg:text-8xl">{title}</h1>
      <p class="mt-4 max-w-xl font-mono text-sm uppercase text-accent">{L(show.tagline, lang)}</p>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-ink-faint sm:text-lg">{synopsis}</p>

      <div class="mt-7 flex flex-wrap items-center gap-4 border-y border-border py-4 font-mono text-[10px] uppercase text-ink-faint">
        <span>{show.episodeCount} {t(lang, "shows.episodesLabel")}</span>
        <span class="text-border">/</span>
        <span>{show.languages.join(" + ")}</span>
      </div>

      {
        turkishAudio && (
          <p class="mt-5 inline-flex items-center gap-2 border border-border bg-surface px-3 py-2 font-mono text-[10px] uppercase text-ink-faint">
            <span class="h-2 w-2 rounded-full bg-accent"></span>
            {t(lang, "shows.turkishAudio")}
          </p>
        )
      }
      {social && <SeriesSocial social={social} label={t(lang, "shows.watchOn")} />}
    </div>

    {
      featured && (
        <div class="mx-auto w-full max-w-[340px]">
          <div class="mb-3 flex items-center justify-between font-mono text-[9px] uppercase text-ink-faint">
            <span>{t(lang, "work.featuredLabel")}</span>
            <span>{t(lang, "work.episodeLabel")} {String(featured.number).padStart(2, "0")}</span>
          </div>
          <button
            type="button"
            data-video={featSrc}
            data-poster={featured.poster}
            data-title={`${title} — ${L(featured.title, lang)}`}
            class="group relative block aspect-[9/16] w-full overflow-hidden border border-border bg-black text-left shadow-glow-poster transition-colors hover:border-accent focus:outline-none"
            aria-label={`${t(lang, "work.playLabel")}: ${L(featured.title, lang)}`}
          >
            <img src={featured.poster} alt={`${title} — ${L(featured.title, lang)}`} class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
            <div class="poster-vignette"></div>
            <span class="absolute inset-0 flex items-center justify-center">
              <span class="flex h-20 w-20 items-center justify-center rounded-full bg-accent text-bg transition-transform duration-300 group-hover:scale-110">
                <span class="ml-1 h-0 w-0 border-b-[11px] border-l-[18px] border-t-[11px] border-b-transparent border-l-current border-t-transparent" aria-hidden="true"></span>
              </span>
            </span>
            <span class="absolute bottom-3 right-3 bg-bg px-2.5 py-1 font-mono text-[10px] text-ink">
              {featured.duration}
            </span>
          </button>
        </div>
      )
    }
  </div>
</section>
