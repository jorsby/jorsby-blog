---
import VideoPlayer from "./VideoPlayer.astro";
import GenreBadge from "./GenreBadge.astro";
import LanguageBadges from "./LanguageBadges.astro";
import SeriesSocial from "./SeriesSocial.astro";
import { L, showSocial, type Show } from "../data/shows";
import { t, type Lang } from "../i18n/utils";

interface Props {
  show: Show;
  lang?: Lang;
}

const { show, lang = "en" } = Astro.props;
const title = L(show.title, lang);
const synopsis = L(show.synopsis, lang);
const featured = show.episodes[0];
const featSrc = featured?.video[lang] ?? featured?.video.en ?? featured?.video.tr ?? "";
const turkishAudio = lang === "en" && show.primaryLang === "tr";
const social = showSocial(show, lang);
---

<section class="border-b border-border/50 bg-cinematic px-6 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl">
    <p class="mb-4 font-mono text-xs uppercase tracking-wider text-accent-ink">{t(lang, "work.indexEyebrow")}</p>
    <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
      <div>
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <GenreBadge genre={show.genre} lang={lang} />
          <LanguageBadges languages={show.languages} />
        </div>
        <h1 class="font-display text-4xl font-extrabold leading-tight text-ink sm:text-6xl">{title}</h1>
        <p class="mt-3 text-lg font-medium text-accent-ink">{L(show.tagline, lang)}</p>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-neutral-600">{synopsis}</p>
        {
          turkishAudio && (
            <p class="mt-4 inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-3 py-1.5 font-mono text-xs text-neutral-600">
              <svg class="h-4 w-4 text-accent-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M11 5 6 9H2v6h4l5 4V5Z"/><path d="M15.5 8.5a5 5 0 0 1 0 7"/></svg>
              {t(lang, "shows.turkishAudio")}
            </p>
          )
        }
        {social && <SeriesSocial social={social} label={t(lang, "shows.watchOn")} />}
      </div>
      {
        featured && (
          <div class="mx-auto w-full max-w-[320px]">
            <p class="mb-3 text-center font-mono text-xs text-neutral-500">
              {t(lang, "work.featuredLabel")} · {t(lang, "work.episodeLabel")} {featured.number}
            </p>
            <VideoPlayer src={featSrc} poster={featured.poster} controls label={`${title} — ${L(featured.title, lang)}`} />
          </div>
        )
      }
    </div>
  </div>
</section>
