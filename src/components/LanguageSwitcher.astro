---
import { languages, type Lang } from "../i18n/utils";
import { getAlternateLangPath } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
---

<div class="flex items-center gap-1 rounded-lg border border-border bg-surface px-1 py-0.5">
  {Object.entries(languages).map(([code, label]) => (
    <a
      href={getAlternateLangPath(currentPath, code as Lang)}
      class:list={[
        "rounded-md px-2 py-1 font-mono text-xs transition-colors",
        code === lang
          ? "bg-accent/15 text-accent"
          : "text-neutral-500 hover:text-neutral-300",
      ]}
      aria-label={`Switch to ${label}`}
      aria-current={code === lang ? "true" : undefined}
    >
      {code.toUpperCase()}
    </a>
  ))}
</div>
