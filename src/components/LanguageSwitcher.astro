---
import { languages, type Lang } from "../i18n/utils";
import { getAlternateLangPath } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
---

<div class="inline-flex items-center gap-1 rounded-lg border border-border bg-surface p-1">
  {Object.entries(languages).map(([code, label]) => (
    <a
      href={getAlternateLangPath(currentPath, code as Lang)}
      class:list={[
        "rounded-md px-3 py-1.5 font-mono text-xs transition-colors",
        code === lang
          ? "bg-accent/15 text-accent-ink"
          : "text-ink-faint hover:text-neutral-800",
      ]}
      aria-label={`Switch to ${label}`}
      aria-current={code === lang ? "true" : undefined}
    >
      {code.toUpperCase()}
    </a>
  ))}
</div>
