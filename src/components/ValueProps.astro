---
import SectionHeader from "./SectionHeader.astro";
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const values = [
  {
    title: t(lang, "value.speed.title"),
    desc: t(lang, "value.speed.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/></svg>`,
  },
  {
    title: t(lang, "value.cost.title"),
    desc: t(lang, "value.cost.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0L3 13V5a2 2 0 0 1 2-2h8l7.6 7.6a2 2 0 0 1 0 2.8Z"/><circle cx="7.5" cy="7.5" r="1.5"/></svg>`,
  },
  {
    title: t(lang, "value.scale.title"),
    desc: t(lang, "value.scale.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m12 3 9 5-9 5-9-5 9-5Z"/><path d="m3 13 9 5 9-5"/></svg>`,
  },
  {
    title: t(lang, "value.reach.title"),
    desc: t(lang, "value.reach.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 3.5 6 3.5 9S14.5 18.5 12 21c-2.5-2.5-3.5-6-3.5-9S9.5 5.5 12 3Z"/></svg>`,
  },
];
---

<section class="fade-in relative overflow-hidden border-t border-border/50 bg-cinematic px-6 py-14 sm:py-20">
  <div class="aurora"></div>
  <div class="relative z-10 mx-auto max-w-6xl">
    <SectionHeader align="center" title={t(lang, "value.title")} subtitle={t(lang, "value.subtitle")} />

    <!-- A compact band, not another card wall — dividers carry the structure -->
    <div class="mt-12 grid grid-cols-1 gap-y-10 sm:grid-cols-2 sm:gap-y-12 lg:grid-cols-4 lg:divide-x lg:divide-border/60">
      {
        values.map((v) => (
          <div class="lg:px-8 lg:first:pl-0 lg:last:pr-0">
            <span
              class="mx-auto flex h-10 w-10 items-center justify-center rounded-full border border-accent/40 bg-accent/10 text-accent-deep sm:mx-0 [&>svg]:h-5 [&>svg]:w-5"
              set:html={v.icon}
            />
            <h3 class="mt-4 text-center text-lg font-semibold text-neutral-900 sm:text-left">{v.title}</h3>
            <p class="mt-2 text-center text-sm leading-relaxed text-ink-faint sm:text-left">{v.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
