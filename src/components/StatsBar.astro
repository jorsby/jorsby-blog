---
import { portfolioStats } from "../data/shows";
import { stats as traction } from "../data/stats";
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const s = portfolioStats();

const stats = [
  { value: String(s.shows), label: t(lang, "stats.showsLabel") },
  { value: String(s.genres), label: t(lang, "stats.genresLabel") },
  { value: String(s.languages), label: t(lang, "stats.languagesLabel") },
  { value: `${traction.totals.episodes}+`, label: t(lang, "stats.episodesLabel") },
];
---

<section class="fade-in border-y border-border bg-surface px-5 py-12 sm:px-8 sm:py-14">
  <div class="page-shell">
    <p class="eyebrow mb-6 text-center">
      {t(lang, "stats.eyebrow")}
    </p>
    <dl class="grid grid-cols-2 gap-px border border-border bg-border sm:grid-cols-4">
      {
        stats.map((st) => (
          <div class="bg-bg px-3 py-7 text-center">
            <dt class="font-display text-4xl text-ink sm:text-5xl">{st.value}</dt>
            <dd class="mt-1.5 font-mono text-[10px] uppercase text-ink-faint">{st.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
