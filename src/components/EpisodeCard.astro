---
import type { Episode } from "../data/episodes";
import { t, type Lang } from "../i18n/utils";

interface Props {
  episode: Episode;
  lang?: Lang;
  index?: number;
  href?: string; // when set, the card links here instead of opening the lightbox
}

const { episode, lang = "en", index = 0, href } = Astro.props;

const nn = String(episode.number).padStart(2, "0");
const delay = ["", "fade-in-delay-1", "fade-in-delay-2", "fade-in-delay-3"][index % 4];
const epLabel = t(lang, "work.episodeLabel");

const Tag = href ? "a" : "button";
const interactiveProps = href
  ? { href }
  : {
      type: "button",
      "data-video": episode.videoUrl,
      "data-poster": episode.posterUrl,
      "data-title": `${epLabel} ${nn} — ${episode.title}`,
    };
---

<Tag
  {...interactiveProps}
  class:list={[
    "group fade-in relative block aspect-[9/16] w-full overflow-hidden rounded-xl border border-border bg-surface text-left transition-all duration-300 hover:border-accent/40 hover:shadow-glow focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/60",
    delay,
  ]}
  aria-label={`${t(lang, "work.playLabel")}: ${epLabel} ${episode.number}, ${episode.title}`}
>
  <img
    src={episode.posterUrl}
    alt=""
    loading="lazy"
    class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
  />
  <div class="poster-vignette"></div>

  <span class="absolute left-3 top-3 rounded-md bg-bg/70 px-2 py-1 font-mono text-xs text-accent backdrop-blur">
    {nn}
  </span>

  <span class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover:opacity-100">
    <span class="flex h-14 w-14 items-center justify-center rounded-full border border-accent/60 bg-bg/50 backdrop-blur">
      <svg class="h-5 w-5 translate-x-0.5 text-accent" viewBox="0 0 24 24" fill="currentColor">
        <path d="M8 5v14l11-7z"></path>
      </svg>
    </span>
  </span>

  <div class="absolute inset-x-0 bottom-0 p-3">
    <h3 class="font-display text-sm font-bold leading-tight text-ink">{episode.title}</h3>
    <p class="mt-1 font-mono text-[11px] text-neutral-400">
      {epLabel} {episode.number} &middot; {episode.duration}
    </p>
  </div>
</Tag>
