---
interface Row {
  label: string;
  value: number;
}
interface Props {
  rows: Row[]; // pre-sorted desc
  unit?: string; // e.g. "views"
}
const { rows, unit = "" } = Astro.props;

const max = Math.max(...rows.map((r) => r.value), 1);
const fmt = (n: number) =>
  new Intl.NumberFormat("en", { notation: "compact", maximumFractionDigits: 1 }).format(n);
// Honest lengths — rows are pre-filtered upstream; a small floor keeps the
// lowest row reading as data rather than an empty track.
const width = (v: number) => Math.max(2.5, +((v / max) * 100).toFixed(1));
---

<div class="space-y-3.5">
  {
    rows.map((r, i) => (
      <div>
        <div class="mb-1 flex items-baseline justify-between gap-3">
          <span class="truncate text-sm font-medium text-ink-soft">{r.label}</span>
          <span class="shrink-0 font-mono text-xs text-ink-faint">
            {fmt(r.value)}
            {unit && ` ${unit}`}
          </span>
        </div>
        <div class="h-2.5 w-full overflow-hidden bg-white/10">
          <div
            class:list={["bar-grow h-full", `grow-bar-${Math.min(i + 1, 6)}`]}
            style={`width:${width(r.value)}%;background:linear-gradient(90deg,#64d8cb,#e8ff47)`}
          />
        </div>
      </div>
    ))
  }
</div>
