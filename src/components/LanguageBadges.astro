---
interface Props {
  languages: string[];
}

const { languages } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {
    languages.map((l) => (
      <span class="rounded-full border border-accent/40 bg-accent/10 px-2.5 py-0.5 font-mono text-xs text-accent-ink">
        {l}
      </span>
    ))
  }
</div>
