---
import SectionHeader from "./SectionHeader.astro";
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const services = [
  {
    title: t(lang, "services.educational.title"),
    desc: t(lang, "services.educational.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l9-4 9 4-9 4-9-4Z"/><path d="M7 10v5c0 1.7 2.2 3 5 3s5-1.3 5-3v-5"/><path d="M21 8v5"/></svg>`,
  },
  {
    title: t(lang, "services.series.title"),
    desc: t(lang, "services.series.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="7" y="2" width="10" height="20" rx="2"/><path d="M10.5 18h3"/></svg>`,
  },
  {
    title: t(lang, "services.history.title"),
    desc: t(lang, "services.history.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2.5" y="5" width="19" height="14" rx="2"/><path d="M10 9.5l5 2.5-5 2.5v-5Z"/></svg>`,
  },
  {
    title: t(lang, "services.character.title"),
    desc: t(lang, "services.character.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><path d="M16 6a3 3 0 0 1 0 6M19 20c0-2.5-1.2-4.7-3-6"/></svg>`,
  },
];
---

<section id="services" class="fade-in relative overflow-hidden border-t border-border/50 px-6 py-16 sm:py-24">
  <div class="aurora-mid"></div>
  <div class="relative z-10 mx-auto max-w-6xl">
    <SectionHeader title={t(lang, "services.title")} subtitle={t(lang, "services.subtitle")} />

    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((s) => (
          <div class="group glass rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lift">
            <span
              class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-accent/30 bg-accent/10 text-accent-deep [&>svg]:h-5 [&>svg]:w-5"
              set:html={s.icon}
            />
            <h3 class="mb-2 text-lg font-semibold text-neutral-900">{s.title}</h3>
            <p class="text-sm leading-relaxed text-ink-faint">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
