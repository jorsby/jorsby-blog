---
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const services = [
  {
    title: t(lang, "services.brand.title"),
    desc: t(lang, "services.brand.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 4v16M17 4v16M3 9h4M3 15h4M17 9h4M17 15h4"/></svg>`,
  },
  {
    title: t(lang, "services.launch.title"),
    desc: t(lang, "services.launch.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 13c0-5 3-9 7-11 4 2 7 6 7 11l-2 4H7l-2-4Z"/><circle cx="12" cy="9" r="2"/><path d="M9 18l-1 3M15 18l1 3"/></svg>`,
  },
  {
    title: t(lang, "services.recruit.title"),
    desc: t(lang, "services.recruit.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3.3 2.7-6 6-6s6 2.7 6 6"/><path d="M16 6a3 3 0 0 1 0 6M19 20c0-2.5-1.2-4.7-3-6"/></svg>`,
  },
  {
    title: t(lang, "services.education.title"),
    desc: t(lang, "services.education.desc"),
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l9-4 9 4-9 4-9-4Z"/><path d="M7 10v5c0 1.7 2.2 3 5 3s5-1.3 5-3v-5"/><path d="M21 8v5"/></svg>`,
  },
];
---

<section id="services" class="fade-in border-t border-border/50 px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <h2 class="font-display text-3xl font-extrabold text-ink sm:text-4xl">
      {t(lang, "services.title")}
    </h2>
    <p class="mt-3 max-w-2xl text-neutral-400">{t(lang, "services.subtitle")}</p>

    <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((s) => (
          <div class="group rounded-xl border border-border p-6 transition-all duration-300 hover:border-accent/30 hover:bg-surface/50">
            <span
              class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg border border-border bg-surface text-accent [&>svg]:h-5 [&>svg]:w-5"
              set:html={s.icon}
            />
            <h3 class="mb-2 text-lg font-semibold text-neutral-100">{s.title}</h3>
            <p class="text-sm leading-relaxed text-neutral-400">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
