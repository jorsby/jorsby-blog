---
import { t, type Lang } from "../i18n/utils";
import { siteMedia } from "../data/siteMedia";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const services = [
  {
    title: t(lang, "services.series.title"),
    desc: t(lang, "services.series.desc"),
    meta: lang === "tr" ? "9:16 BÖLÜMLER · DEVAM EDEN KARAKTERLER" : "9:16 EPISODES · CLIFFHANGERS · RECURRING CAST",
    poster: siteMedia.servicePreviews.verticalDrama,
  },
  {
    title: t(lang, "services.history.title"),
    desc: t(lang, "services.history.desc"),
    meta: lang === "tr" ? "REELS · TIKTOK · SHORTS · HER GÜN" : "REELS · TIKTOK · SHORTS · DAILY",
    poster: siteMedia.servicePreviews.shortForm,
  },
  {
    title: t(lang, "services.educational.title"),
    desc: t(lang, "services.educational.desc"),
    meta: lang === "tr" ? "BİLİM · TARİH · İŞ DÜNYASI" : "SCIENCE · HISTORY · BUSINESS",
    poster: siteMedia.servicePreviews.documentary,
  },
  {
    title: t(lang, "services.character.title"),
    desc: t(lang, "services.character.desc"),
    meta: lang === "tr" ? "SENARYO · SES · KURGU · YERELLEŞTİRME" : "SCRIPT · VOICE · EDIT · LOCALIZE",
    poster: siteMedia.servicePreviews.localized,
  },
];
---

<section id="services" class="fade-in border-b border-border px-5 py-20 sm:px-8 sm:py-28">
  <div class="page-shell">
    <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:gap-16">
      <div>
        <p class="eyebrow">{lang === "tr" ? "NE ÜRETİYORUZ" : "WHAT WE MAKE"}</p>
        <h2 class="mt-4 font-display text-5xl uppercase leading-none text-ink sm:text-7xl">
          {t(lang, "services.title")}
        </h2>
        <p class="mt-5 max-w-md leading-relaxed text-ink-faint">{t(lang, "services.subtitle")}</p>
      </div>

      <div class="border-b border-border">
        {
          services.map((service, index) => (
            <article
              data-service-preview={service.poster}
              class="group border-t border-border px-1 py-7 transition-colors hover:bg-surface-light sm:px-4 sm:py-8"
            >
              <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_minmax(250px,0.72fr)] sm:items-center sm:gap-8">
                <div class="flex min-w-0 items-baseline gap-4 sm:gap-6">
                  <span class="shrink-0 font-mono text-xs text-accent">{String(index + 1).padStart(2, "0")}</span>
                  <h3 class="font-display text-3xl uppercase leading-none text-ink transition-transform duration-300 group-hover:translate-x-2 group-hover:text-accent sm:text-4xl">
                    {service.title}
                  </h3>
                </div>
                <div>
                  <p class="text-sm leading-relaxed text-ink-faint">{service.desc}</p>
                  <p class="mt-3 font-mono text-[9px] uppercase text-accent/80">{service.meta}</p>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>

  <div data-floating-preview class="hidden lg:block" aria-hidden="true">
    <img data-floating-preview-image src={services[0].poster} alt="" class="h-full w-full object-cover" />
    <div class="poster-vignette"></div>
    <span class="absolute bottom-2 left-2 bg-bg/85 px-2 py-1 font-mono text-[8px] uppercase text-accent">JORSBY / 2026</span>
  </div>

</section>
