---
import ShowsWall from "./ShowsWall.astro";
import { t, localizedPath, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const workPath = localizedPath("/work", lang);
---

<section id="shows" class="fade-in border-t border-border/50 px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow mb-3">{t(lang, "shows.title")}</p>
        <h2 class="max-w-2xl font-display text-3xl font-extrabold text-ink sm:text-5xl">
          {t(lang, "work.indexTitle")}
        </h2>
        <p class="mt-3 max-w-xl text-ink-faint">{t(lang, "shows.subtitle")}</p>
      </div>
      <a
        href={workPath}
        class="inline-flex shrink-0 items-center gap-1 font-mono text-sm text-accent-ink transition-colors hover:text-accent-warm"
      >
        {t(lang, "shows.viewAll")}
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <div class="mt-10">
      <ShowsWall lang={lang} />
    </div>
  </div>
</section>
