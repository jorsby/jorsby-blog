---
// One locked rhythm for section openers: eyebrow → h2 → subtitle.
// `align="center"` for banded sections, default left elsewhere.
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { eyebrow, title, subtitle, align = "left" } = Astro.props;
const centered = align === "center";
---

<div class:list={[centered && "mx-auto max-w-2xl text-center"]}>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class:list={["font-display text-5xl uppercase leading-none text-ink sm:text-7xl", !centered && "max-w-3xl"]}>
    {title}
  </h2>
  {subtitle && <p class:list={["mt-4 leading-relaxed text-ink-faint", !centered && "max-w-2xl"]}>{subtitle}</p>}
</div>
