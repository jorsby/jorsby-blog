---
import { genreLabel, type Lang } from "../i18n/utils";
import type { Genre } from "../data/shows";

interface Props {
  genre: Genre;
  lang?: Lang;
  class?: string;
}

const { genre, lang = "en", class: extra = "" } = Astro.props;

// A subtle per-genre tint so the wall reads as a range of shows, not one look.
const TINT: Record<Genre, string> = {
  drama: "border-rose-400/30 bg-rose-400/10 text-rose-200",
  moral: "border-emerald-400/30 bg-emerald-400/10 text-emerald-200",
  science: "border-sky-400/30 bg-sky-400/10 text-sky-200",
  history: "border-amber-400/30 bg-amber-400/10 text-amber-200",
  "dark-history": "border-neutral-400/30 bg-neutral-400/10 text-neutral-200",
  finance: "border-teal-400/30 bg-teal-400/10 text-teal-200",
};
---

<span
  class:list={[
    "inline-flex items-center rounded-full border px-2.5 py-0.5 font-mono text-[11px] uppercase tracking-wide",
    TINT[genre],
    extra,
  ]}
>
  {genreLabel(lang, genre)}
</span>
