---
import { genreLabel, type Lang } from "../i18n/utils";
import type { Genre } from "../data/shows";

interface Props {
  genre: Genre;
  lang?: Lang;
  onDark?: boolean; // true when placed over a dark poster (ShowCard)
  class?: string;
}

const { genre, lang = "en", onDark = false, class: extra = "" } = Astro.props;

// One quiet chip for every genre — identity carried by a small muted-hue dot,
// so the badges stay on the porcelain+gold palette instead of candy tints.
const DOT: Record<Genre, string> = {
  drama: "#c25e7d",
  moral: "#4e9b7a",
  science: "#4e7fb0",
  history: "#c08a1f",
  "dark-history": "#6f6558",
  finance: "#3f8f8a",
};

const chip = onDark
  ? "border-white/25 bg-bg/70 text-media-ink/90 backdrop-blur"
  : "border-border bg-surface text-ink-soft";
---

<span
  class:list={[
    "inline-flex items-center gap-1.5 whitespace-nowrap border px-2.5 py-1 font-mono text-[10px] uppercase",
    chip,
    extra,
  ]}
>
  <span class="h-1.5 w-1.5 shrink-0 rounded-full" style={`background:${DOT[genre]}`}></span>
  {genreLabel(lang, genre)}
</span>
