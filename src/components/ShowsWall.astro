---
import ShowCard from "./ShowCard.astro";
import { shows as allShows, allGenres, type Show } from "../data/shows";
import { t, genreLabel, formatLabel, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
  shows?: Show[];
  filter?: boolean; // show the filter chips
  layout?: "grid" | "featured";
}

const { lang = "en", shows = allShows, filter = false, layout = "grid" } = Astro.props;
const ordered = [...shows].sort((a, b) => a.order - b.order);

const genres = allGenres();
const chip =
  "filter-chip border border-border px-3 py-1.5 font-mono text-[11px] uppercase text-ink-faint transition-colors hover:border-accent hover:text-ink data-[active]:border-accent data-[active]:bg-accent data-[active]:text-bg";
const filterLabel = "w-16 shrink-0 font-mono text-[11px] uppercase text-ink-faint";
const gridClass = layout === "featured"
  ? "grid grid-cols-2 gap-x-3 gap-y-10 sm:gap-x-5 lg:grid-cols-4"
  : "grid grid-cols-2 gap-x-3 gap-y-10 sm:grid-cols-3 sm:gap-x-5";
---

{
  filter && (
    <div id="show-filters" class="mb-8 flex flex-col gap-3" data-genre="all" data-format="all" data-langs="all">
      <div class="flex items-center gap-2">
        <span class={filterLabel}>{t(lang, "filter.genre")}</span>
        <div class="flex flex-wrap items-center gap-2">
          <button type="button" class={chip} data-set="genre" data-val="all" data-active>{t(lang, "filter.all")}</button>
          {genres.map((g) => (
            <button type="button" class={chip} data-set="genre" data-val={g}>{genreLabel(lang, g)}</button>
          ))}
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class={filterLabel}>{t(lang, "filter.format")}</span>
        <div class="flex flex-wrap items-center gap-2">
          <button type="button" class={chip} data-set="format" data-val="all" data-active>{t(lang, "filter.all")}</button>
          <button type="button" class={chip} data-set="format" data-val="series">{formatLabel(lang, "series")}</button>
          <button type="button" class={chip} data-set="format" data-val="shorts">{formatLabel(lang, "shorts")}</button>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class={filterLabel}>{t(lang, "filter.language")}</span>
        <div class="flex flex-wrap items-center gap-2">
          <button type="button" class={chip} data-set="langs" data-val="all" data-active>{t(lang, "filter.all")}</button>
          <button type="button" class={chip} data-set="langs" data-val="EN">EN</button>
          <button type="button" class={chip} data-set="langs" data-val="TR">TR</button>
        </div>
      </div>
    </div>
  )
}

<div id="shows-grid" class={gridClass}>
  {
    ordered.map((show, i) => (
      <ShowCard show={show} lang={lang} index={i} />
    ))
  }
</div>

{
  filter && (
    <p id="shows-empty" class="mt-8 hidden text-center font-mono text-sm text-ink-faint">
      {t(lang, "shows.empty")}
    </p>
  )
}

{
  filter && (
    <script>
      const root = document.getElementById("show-filters");
      const grid = document.getElementById("shows-grid");
      const empty = document.getElementById("shows-empty");
      if (root && grid) {
        const cards = Array.from(grid.children) as HTMLElement[];
        const apply = () => {
          const g = root.dataset.genre;
          const f = root.dataset.format;
          const l = root.dataset.langs;
          let shown = 0;
          cards.forEach((c) => {
            const ok =
              (g === "all" || c.dataset.genre === g) &&
              (f === "all" || c.dataset.format === f) &&
              (l === "all" || (c.dataset.langs || "").split(" ").includes(l!));
            c.classList.toggle("hidden", !ok);
            if (ok) shown++;
          });
          empty?.classList.toggle("hidden", shown !== 0);
        };
        root.querySelectorAll<HTMLButtonElement>("button[data-set]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const set = btn.dataset.set!;
            root
              .querySelectorAll<HTMLButtonElement>(`button[data-set="${set}"]`)
              .forEach((b) => delete b.dataset.active);
            btn.dataset.active = "";
            root.dataset[set] = btn.dataset.val!;
            apply();
          });
        });
      }
    </script>
  )
}
