---
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const steps = [
  { title: t(lang, "process.step1.title"), desc: t(lang, "process.step1.desc") },
  { title: t(lang, "process.step2.title"), desc: t(lang, "process.step2.desc") },
  { title: t(lang, "process.step3.title"), desc: t(lang, "process.step3.desc") },
  { title: t(lang, "process.step4.title"), desc: t(lang, "process.step4.desc") },
];
---

<section class="fade-in border-t border-border/50 px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <h2 class="font-display text-3xl font-extrabold text-ink sm:text-4xl">
      {t(lang, "process.title")}
    </h2>
    <p class="mt-3 max-w-2xl text-neutral-400">{t(lang, "process.subtitle")}</p>

    <ol class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((s, i) => (
          <li class="rounded-xl border border-border p-6">
            <span class="font-display text-4xl font-extrabold text-accent/30">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="mt-3 text-lg font-semibold text-neutral-100">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-400">{s.desc}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
