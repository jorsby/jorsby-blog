---
import SectionHeader from "./SectionHeader.astro";
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const steps = [
  { title: t(lang, "process.step1.title"), desc: t(lang, "process.step1.desc") },
  { title: t(lang, "process.step2.title"), desc: t(lang, "process.step2.desc") },
  { title: t(lang, "process.step3.title"), desc: t(lang, "process.step3.desc") },
  { title: t(lang, "process.step4.title"), desc: t(lang, "process.step4.desc") },
];
---

<section id="process" class="fade-in border-b border-border px-5 py-20 sm:px-8 sm:py-28">
  <div class="page-shell">
    <SectionHeader eyebrow={lang === "tr" ? "SÜREÇ" : "THE PROCESS"} title={t(lang, "process.title")} subtitle={t(lang, "process.subtitle")} />

    <ol class="mt-12 grid gap-px border border-border bg-border sm:grid-cols-2 lg:grid-cols-4">
      {
        steps.map((s, i) => (
          <li class="group min-h-[220px] bg-bg p-6 transition-colors hover:bg-surface-light sm:p-7">
            <span class="font-display text-4xl text-accent">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div class="mt-8">
              <h3 class="text-sm font-bold uppercase text-ink">{s.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-faint">{s.desc}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
