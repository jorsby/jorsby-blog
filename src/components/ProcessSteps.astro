---
import SectionHeader from "./SectionHeader.astro";
import { t, type Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;

const steps = [
  { title: t(lang, "process.step1.title"), desc: t(lang, "process.step1.desc") },
  { title: t(lang, "process.step2.title"), desc: t(lang, "process.step2.desc") },
  { title: t(lang, "process.step3.title"), desc: t(lang, "process.step3.desc") },
  { title: t(lang, "process.step4.title"), desc: t(lang, "process.step4.desc") },
];
---

<section class="fade-in border-t border-border/50 px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-6xl">
    <SectionHeader title={t(lang, "process.title")} subtitle={t(lang, "process.subtitle")} />

    <!-- Connected timeline: gold line through the step markers (no card chrome) -->
    <ol class="relative mt-12 grid gap-10 lg:grid-cols-4 lg:gap-8">
      <div
        class="absolute bottom-2 left-[19px] top-2 w-px bg-gradient-to-b from-accent/60 via-accent/30 to-accent/10 lg:bottom-auto lg:left-5 lg:right-24 lg:top-5 lg:h-px lg:w-auto lg:bg-gradient-to-r"
        aria-hidden="true"
      >
      </div>
      {
        steps.map((s, i) => (
          <li class="relative flex gap-5 lg:block">
            <span class="relative z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-accent/50 bg-bg font-mono text-sm font-medium text-accent-ink shadow-glow">
              {String(i + 1).padStart(2, "0")}
            </span>
            <div class="lg:mt-4">
              <h3 class="text-lg font-semibold text-neutral-900">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-faint">{s.desc}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
