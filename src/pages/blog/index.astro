---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="All posts from the Jorsby blog on AI agent engineering.">
  <h1 class="mb-2 text-3xl font-bold text-neutral-100">Blog</h1>
  <p class="mb-10 text-neutral-400">
    Writing about what we learn building multi-agent systems.
  </p>

  {posts.length > 0 ? (
    <div class="flex flex-col gap-4">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  ) : (
    <p class="text-neutral-500">No posts yet. Check back soon.</p>
  )}
</BaseLayout>
