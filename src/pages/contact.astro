---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";
import { t } from "../i18n/utils";

const lang = "en" as const;
---

<BaseLayout title={t(lang, "contact.title")} description={t(lang, "contact.subtitle")} lang={lang}>
  <div class="fade-in">
    <h1 class="font-display text-3xl font-extrabold text-ink sm:text-4xl">{t(lang, "contact.title")}</h1>
    <p class="mt-3 text-lg text-neutral-400">{t(lang, "contact.subtitle")}</p>
  </div>

  <div class="fade-in mt-10">
    <ContactForm lang={lang} />
  </div>

  <p class="fade-in mt-10 border-t border-border/50 pt-6 text-sm text-neutral-500">
    {t(lang, "contact.directLabel")} {t(lang, "contact.directText")}{" "}
    <a href="mailto:serhat@jorsby.ai" class="text-accent transition-colors hover:text-accent-warm">serhat@jorsby.ai</a>
    {" · "}
    <a href="https://x.com/jorsby_en" target="_blank" rel="noopener noreferrer" class="text-accent transition-colors hover:text-accent-warm">@jorsby_en</a>
  </p>
</BaseLayout>
