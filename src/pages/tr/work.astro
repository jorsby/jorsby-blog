---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShowsWall from "../../components/ShowsWall.astro";
import StatsBar from "../../components/StatsBar.astro";
import CTABanner from "../../components/CTABanner.astro";
import { shows, L } from "../../data/shows";
import { t, localizedPath } from "../../i18n/utils";

const lang = "tr" as const;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: t(lang, "work.indexTitle"),
  itemListElement: [...shows]
    .sort((a, b) => a.order - b.order)
    .map((s, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: L(s.title, lang),
      url: new URL(localizedPath(`/shows/${s.slug}`, lang), Astro.site).toString(),
    })),
};
---

<BaseLayout title={t(lang, "work.indexTitle")} description={t(lang, "work.indexSubtitle")} fullWidth lang={lang} jsonLd={jsonLd}>
  <section class="relative overflow-hidden border-b border-border/50 bg-cinematic px-6 py-16 sm:py-20">
    <div class="aurora"></div>
    <div class="relative z-10 mx-auto max-w-6xl">
      <p class="eyebrow mb-3">{t(lang, "work.portfolioEyebrow")}</p>
      <h1 class="max-w-3xl font-display text-4xl font-extrabold leading-tight text-ink sm:text-6xl">
        {t(lang, "nav.work")}
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-faint">{t(lang, "work.indexSubtitle")}</p>
    </div>
  </section>

  <StatsBar lang={lang} />

  <section class="fade-in px-6 py-16 sm:py-20">
    <div class="mx-auto max-w-6xl">
      <ShowsWall lang={lang} filter />
    </div>
  </section>

  <CTABanner lang={lang} />
</BaseLayout>
