---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactForm from "../../components/ContactForm.astro";
import { t } from "../../i18n/utils";

const lang = "tr" as const;

const nextSteps = [
  t(lang, "contact.next1"),
  t(lang, "contact.next2"),
  t(lang, "contact.next3"),
];
---

<BaseLayout title={t(lang, "contact.title")} description={t(lang, "contact.subtitle")} fullWidth lang={lang}>
  <section class="relative overflow-hidden border-b border-border/50 bg-cinematic px-6 py-16 sm:py-20">
    <div class="aurora"></div>
    <div class="relative z-10 mx-auto max-w-6xl">
      <p class="eyebrow mb-3">{t(lang, "nav.contact")}</p>
      <h1 class="max-w-3xl font-display text-4xl font-extrabold leading-tight text-ink sm:text-5xl">
        {t(lang, "contact.title")}
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-ink-faint">{t(lang, "contact.subtitle")}</p>
    </div>
  </section>

  <section class="relative overflow-hidden px-6 py-14 sm:py-16">
    <div class="aurora-mid"></div>
    <div class="relative z-10 mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="fade-in glass rounded-2xl p-6 sm:p-8">
        <ContactForm lang={lang} />
      </div>

      <div class="fade-in fade-in-delay-1">
        <h2 class="eyebrow-dim">{t(lang, "contact.nextTitle")}</h2>
        <ol class="mt-6 space-y-6">
          {
            nextSteps.map((step, i) => (
              <li class="flex gap-4">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-accent/50 bg-bg font-mono text-sm text-accent-ink">
                  {i + 1}
                </span>
                <p class="pt-1.5 text-sm leading-relaxed text-ink-soft">{step}</p>
              </li>
            ))
          }
        </ol>

        <p class="mt-10 border-t border-border/50 pt-6 text-sm text-ink-faint">
          {t(lang, "contact.directLabel")} {t(lang, "contact.directText")}{" "}
          <a href="mailto:serhat@jorsby.ai" class="font-medium text-accent-ink transition-colors hover:text-accent-deep">serhat@jorsby.ai</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
