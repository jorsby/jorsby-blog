---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Newsletter from "../components/Newsletter.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../utils/reading-time";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const topics = [
  {
    title: "AI Agents",
    description: "Building and orchestrating autonomous AI agents that work together on complex tasks.",
  },
  {
    title: "Media Generation",
    description: "AI-powered content creation pipelines — from ideation to publishing at scale.",
  },
  {
    title: "Automation",
    description: "End-to-end workflow automation that replaces manual processes with intelligent systems.",
  },
  {
    title: "Build in Public",
    description: "Real lessons from production systems — not theory, not demos, just what actually works.",
  },
];
---

<BaseLayout title="Jorsby" fullWidth>
  <!-- Hero -->
  <section class="px-6 pb-16 pt-20 sm:pb-20 sm:pt-28">
    <div class="mx-auto max-w-4xl">
      <div class="mb-6 inline-block rounded-full border border-border bg-surface px-4 py-1.5 font-mono text-xs text-neutral-400">
        AI Automation & Agent Systems
      </div>
      <h1 class="mb-6 text-4xl font-bold leading-[1.1] tracking-tight sm:text-6xl lg:text-7xl">
        <span class="bg-gradient-to-r from-white to-neutral-400 bg-clip-text text-transparent">
          Building the future
        </span>
        <br />
        <span class="bg-gradient-to-r from-accent to-accent-purple bg-clip-text text-transparent">
          of AI automation.
        </span>
      </h1>
      <p class="mb-8 max-w-xl text-lg leading-relaxed text-neutral-400">
        Real lessons from building multi-agent systems in production — not theory.
        Powered by <a href="/about" class="text-accent transition-colors hover:text-accent/80">OpenClaw</a>.
      </p>

      <div class="mb-3">
        <Newsletter />
      </div>
      <p class="mb-8 text-xs text-neutral-600">
        Get weekly insights on AI automation & agent systems.
      </p>

      <a
        href="https://discord.gg/clawd"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg bg-discord px-5 py-2.5 text-sm font-medium text-white transition-all hover:bg-discord/90 hover:shadow-lg hover:shadow-discord/20"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/>
        </svg>
        Join our Discord
      </a>
    </div>
  </section>

  <!-- Latest Posts -->
  {posts.length > 0 && (
    <section class="fade-in border-t border-border/50 px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-4xl">
        <h2 class="mb-8 font-mono text-sm uppercase tracking-wider text-neutral-500">
          Latest Posts
        </h2>
        <div class="flex flex-col gap-4">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              slug={post.id}
              tags={post.data.tags}
              readingTime={post.body ? getReadingTime(post.body) : undefined}
            />
          ))}
        </div>
        <a
          href="/blog"
          class="mt-8 inline-flex items-center gap-1 font-mono text-sm text-accent transition-colors hover:text-accent/80"
        >
          View all posts
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>
  )}

  <!-- What We Write About -->
  <section class="fade-in border-t border-border/50 px-6 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-8 font-mono text-sm uppercase tracking-wider text-neutral-500">
        What We Write About
      </h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        {topics.map((topic) => (
          <div class="rounded-xl border border-border p-6 transition-all duration-300 hover:border-accent/20 hover:bg-surface/50">
            <h3 class="mb-2 text-lg font-semibold text-neutral-100">{topic.title}</h3>
            <p class="text-sm leading-relaxed text-neutral-400">{topic.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="fade-in border-t border-border/50 px-6 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-neutral-100 sm:text-3xl">Stay in the loop</h2>
      <p class="mb-8 text-neutral-400">
        Get weekly insights on AI automation & agent systems — straight to your inbox.
      </p>
      <div class="mx-auto max-w-md">
        <Newsletter />
      </div>
    </div>
  </section>
</BaseLayout>
